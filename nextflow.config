/*
 * Configuração principal do pipeline MD-GROMACS
 */

params {
    // --- Entrada/Saída ---
    input          = null
    outdir         = "${System.getenv('HOME')}/gromacs/results"

    // --- Parâmetros físicos ---
    pH             = 8.2
    time_ns        = 200
    forcefield     = 'amber99sb-ildn'
    water          = 'tip3p'
    nacl_conc      = 0.10   // midgut inseto é hipotônico; literatura usa 0.10-0.15 M
    cation         = 'K'    // hemolínfa de insetos é dominada por K+ (vs NA em mamíferos)
    temperature    = 300
    box_dist       = 1.5   // 1.5 nm evita artefatos PBC em receptores maiores (~300+ resíduos)
    box_type       = 'dodecahedron'

    // --- GROMACS ---
    gmx_cmd        = 'gmx_mpi'      // build conda-forge com CUDA usa gmx_mpi
    mpi_cmd        = 'mpirun -np 1' // 1 rank MPI + ntomp threads OpenMP
    use_gpu        = true
    gpu_id         = 0
    ntomp          = 8
    maxwarn        = 2

    // --- Resíduos de interesse para distâncias (fallback global) ---
    // Preferir definir por sistema no samplesheet (colunas triad_1, triad_2, triad_3)
    triad_1        = 0
    triad_2        = 0
    triad_3        = 0
    triad_4        = 0   // bolsão S1

    // --- Pipeline MMGBSA robusto ---
    // Filtragem de estabilidade (detecção do plateau do RMSD)
    stability_min_frac      = 0.3   // descarta no mínimo os primeiros 30%
    stability_window_ns     = 5.0   // janela deslizante para detecção de plateau
    stability_threshold     = 0.15  // fração do SD global abaixo da qual = estável

    // Clustering (GROMOS sobre o grupo Ligante)
    cluster_cutoff              = 0.2  // cutoff RMSD em nm
    mmgbsa_n_clusters           = 3    // clusters mais populosos a usar
    mmgbsa_frames_per_cluster   = 50   // frames por cluster → ~150 frames total
}

// Carrega configurações por perfil
profiles {
    local   { includeConfig 'conf/local.config'  }
    slurm   { includeConfig 'conf/slurm.config'  }
    conda   {
        conda.enabled          = true
        conda.useMamba         = true
        process.conda          = "${System.getenv('HOME')}/miniforge3/envs/md-gromacs"
    }
}

// Configuração base de recursos
includeConfig 'conf/base.config'

// Relatório de execução
report {
    enabled = true
    file    = "${params.outdir}/pipeline_report.html"
}
timeline {
    enabled = true
    file    = "${params.outdir}/timeline.html"
}
dag {
    enabled = true
    file    = "${params.outdir}/dag.svg"
}

manifest {
    name            = 'MD-GROMACS'
    description     = 'Pipeline Dinâmica Molecular GROMACS - Complexos Proteína-Peptídeo'
    version         = '1.0.0'
    nextflowVersion = '>=23.04'
}
